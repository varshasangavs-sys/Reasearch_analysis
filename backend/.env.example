# Copy this file to .env and fill in real values. NEVER commit .env.

# --- LLM provider switch ---
# "gemini" or "openai". To swap LLM providers, change this one line and
# make sure the matching API key below is set. Agent code is unchanged.
LLM_PROVIDER=gemini

# --- Provider keys ---
# Required if LLM_PROVIDER=gemini. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Required if LLM_PROVIDER=openai. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Other source keys ---
# Get a free key at https://www.semanticscholar.org/product/api (raises rate
# limits; requests still work without it but get throttled aggressively).
SEMANTIC_SCHOLAR_API_KEY=

# Tavily is the primary web search backend (designed for AI agents — clean
# results, no scraping required). Free tier: 1000 searches/month.
# Get a key at https://app.tavily.com/. If empty, the web tool falls back to
# Gemini's Google Search grounding (only works when LLM_PROVIDER=gemini).
TAVILY_API_KEY=

# --- Gemini models (used when LLM_PROVIDER=gemini) ---
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
# Which model the Synthesizer uses. Leave empty to use GEMINI_PRO_MODEL.
# Free-tier users have 0 Pro quota — set this to gemini-2.5-flash to make
# the Synthesizer work without billing enabled.
GEMINI_SYNTH_MODEL=

# --- OpenAI models (used when LLM_PROVIDER=openai) ---
# OPENAI_FAST_MODEL is used by Planner/Retriever/Critic (cheap+fast).
# OPENAI_SYNTH_MODEL is used by the Synthesizer (higher quality).
# Empty OPENAI_SYNTH_MODEL → falls back to OPENAI_FAST_MODEL.
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_SYNTH_MODEL=gpt-4o

# --- Tunables (all have safe defaults; override only if you need to) ---
MAX_RETRIES=2
RESULTS_PER_SOURCE=5
REQUEST_TIMEOUT_SECONDS=15
ARXIV_DELAY_SECONDS=3.0

# Logging
LOG_LEVEL=INFO
